# MUNET Web - Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# API Configuration
# ===========================================

# AWS API Gateway URL (without trailing slash)
# Example: https://abc123xyz.execute-api.us-east-1.amazonaws.com/prod
VITE_API_URL=https://xxx.execute-api.us-east-1.amazonaws.com/prod

# ===========================================
# Stripe Configuration
# ===========================================

# Stripe Publishable Key (client-side)
# Test: pk_test_xxx
# Live: pk_live_xxx
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ===========================================
# Optional: Development
# ===========================================

# Enable debug mode (logs API calls to console)
# VITE_DEBUG=true

# ===========================================
# Backend Environment Variables (Lambda)
# ===========================================
# These are set in AWS Lambda, not in this file.
# Listed here for reference only.
#
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# FRONTEND_URL=https://museomunet.com
# DYNAMODB_ORDERS_TABLE=munet-orders
# SES_FROM_EMAIL=boletos@museomunet.com
# SES_REGION=us-east-1
